# ============================================================
# TG Monitor Pro - 引擎环境变量配置
# 复制此文件为 .env 并填写实际值
# ============================================================

# ── 必填：Web 管理台连接配置 ─────────────────────────────────
# Web 管理台的访问地址（不含末尾斜杠）
WEB_API_URL=https://your-domain.manus.space

# 引擎通信密钥（必须与 Web 管理台系统设置中的 engine_secret 保持一致）
ENGINE_SECRET=your-engine-secret-key-here

# ── 可选：Telegram Bot 配置 ──────────────────────────────────
BOT_TOKEN=

# ── 可选：Telegram API 配置 ──────────────────────────────────
# 从 https://my.telegram.org/apps 获取
TG_API_ID=
TG_API_HASH=

# ── 可选：代理配置 ───────────────────────────────────────────
PROXY_URL=

# ── 可选：引擎运行参数 ───────────────────────────────────────
SYNC_INTERVAL=30
DM_MIN_INTERVAL=60
LOG_LEVEL=INFO
SESSION_DIR=./sessions
HEALTH_PORT=8080
