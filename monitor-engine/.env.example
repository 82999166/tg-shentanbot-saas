# ============================================================
# TG Monitor Pro - 引擎环境变量配置
# 复制此文件为 .env 并填写实际值
# ============================================================

# ── 必填：Web 管理台连接配置 ─────────────────────────────────
# Web 管理台的访问地址（不含末尾斜杠）
WEB_API_URL=https://your-domain.manus.space

# 引擎通信密钥（必须与 Web 管理台系统设置中的 engine_secret 保持一致）
ENGINE_SECRET=your-engine-secret-key-here

# ── 可选：Telegram Bot 配置 ──────────────────────────────────
BOT_TOKEN=

# ── 可选：Telegram API 配置 ──────────────────────────────────
# 从 https://my.telegram.org/apps 获取
TG_API_ID=
TG_API_HASH=

# ── 可选：代理配置 ───────────────────────────────────────────
PROXY_URL=

# ── 可选：引擎运行参数 ───────────────────────────────────────────
SYNC_INTERVAL=30
DM_MIN_INTERVAL=60
LOG_LEVEL=INFO
SESSION_DIR=./sessions
HEALTH_PORT=7004

# ── TDLib 引擎配置 ─────────────────────────────────────────
# TDLib 持久化数据目录（每账号一个子目录，包含 td.binlog 和加密文件）
TDLIB_DATA_DIR=./tdlib_data

# TDLib 日志级别（0=错误, 1=警告, 2=信息, 3=调试, 4=详细调试）
TDLIB_VERBOSITY=1

# 登录服务端口
LOGIN_SERVICE_PORT=7002

# 引擎 HTTP 服务端口（Web 后端调用引擎接口用）
ENGINE_HTTP_PORT=7001

# Web 后端地址（引擎回调 Web API 用）
# WEB_API_URL 已在上方配置，此处为引擎内部使用的 API 基础地址
# WEB_API_BASE=http://127.0.0.1:7000/api